{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secstudy.local/schema/resource.schema.json",
  "title": "Resource",
  "description": "A curated external link in a subject's `resources` module (Phase 2). `verified` here means 'link last confirmed live', a different provenance model from cards. Resource URLs are NOT restricted to the card source allowlist (e.g. curated YouTube explainers are valid).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "url", "note", "verified"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 80
    },
    "title": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "pattern": "^https://", "format": "uri" },
    "note": { "type": "string", "minLength": 1 },
    "verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
    "tags": {
      "type": "array",
      "description": "Optional lowercase keyword tags.",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    }
  }
}
