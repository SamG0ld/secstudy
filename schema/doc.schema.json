{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secstudy.local/schema/doc.schema.json",
  "title": "Doc",
  "description": "A long-form study doc in a subject's `docs` module (Phase 2). Stub contract — the module is not built in Round 1, but the shape is fixed now so future content validates.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "body", "source", "verified"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 80
    },
    "title": { "type": "string", "minLength": 1 },
    "body": { "type": "string", "description": "Markdown body.", "minLength": 1 },
    "source": { "type": "string", "pattern": "^https://", "format": "uri" },
    "verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "format": "date" },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    }
  }
}
